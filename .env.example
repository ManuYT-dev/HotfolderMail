# Azure App Registration Credentials for Straussdruck Mail Processing
AZURE_CLIENT_ID="your_public_client_id_here"
AZURE_CLIENT_SECRET="your_private_client_secret_here"
AZURE_TENANT_ID="your_tenant_id_here"

LOG_DIR="logs"

# OUTPUT_DIR is the MAIN folder on the SMB share where all customer data
# gets saved. It is a path *inside* the share (SMB_SHARE below), not a local
# disk path — e.g. "Kundendaten" or "Auftraege/2026". Every sender gets one
# stable subfolder created underneath it automatically.
OUTPUT_DIR="Auftraege"

# SMB / network share where the finished + original PDFs get uploaded.
#
# How to find these two values: open the network folder in Windows File
# Explorer and look at the address bar (or right-click the folder -> click
# into the path field). It will show something like:
#
#     \\192.168.1.100\SharedFolder\Auftraege
#       ^^^^^^^^^^^^^ ^^^^^^^^^^^^
#       SMB_SERVER    SMB_SHARE
#
# (If it shows a drive letter like "Z:\" instead of a "\\...\..." path, right-click
# the drive in "This PC" -> Properties, the UNC path is listed there.)
#
# SMB_SERVER: everything right after the first "\\", up to (not including) the next "\"
SMB_SERVER="your_smb_server_ip_or_hostname"
# SMB_SHARE: the next segment after that — just the share's name, nothing more
# (anything after the share name, like "\Auftraege" above, is NOT part of
# SMB_SHARE — that's the OUTPUT_DIR folder path inside the share instead)
SMB_SHARE="your_share_name"
# SMB_USER / SMB_PASSWORD: credentials for a user with write access to the share.
SMB_USER="your_network_username"
SMB_PASSWORD="your_network_password"
