# ── Azure App Registration Credentials ────────────────────────────────────────
# Used by the Microsoft Graph API to fetch emails.
AZURE_CLIENT_ID="your_public_client_id_here"
AZURE_CLIENT_SECRET="your_private_client_secret_here"
AZURE_TENANT_ID="your_tenant_id_here"

# ── Application Settings ──────────────────────────────────────────────────────
LOG_DIR="logs"

# OUTPUT_DIR is the destination where processed customer folders and PDFs are saved.
# Because the application runs in Docker and uses a volume mount to access the 
# network share, this MUST be the path INSIDE the container (e.g., "/mnt/daten").
# 
# NOTE: Do not use Windows UNC paths (like \\192.168.0.25\daten) or SMB 
# credentials here. The network connection is handled entirely by the host OS 
# and mapped via docker-compose.yml.
OUTPUT_DIR="/mnt/daten"

# The folder on your physical Windows machine
HOST_AUFTRAG_PATH="C:/Users/Manuel/Documents/Auftrag"